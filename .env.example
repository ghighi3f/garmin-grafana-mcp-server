# InfluxDB connection
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=GarminStats
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword

# Set to 2 for InfluxDB v2; requires INFLUXDB_TOKEN and INFLUXDB_ORG
INFLUXDB_VERSION=1
INFLUXDB_TOKEN=
INFLUXDB_ORG=

# Measurement names — override if your garmin-grafana schema differs
MEASUREMENT_ACTIVITIES=ActivitySummary
MEASUREMENT_RESTING_HR=DailyStats
MEASUREMENT_HRV=HRV_Intraday

# Measurements for recovery, detail, fitness, and zone tools
MEASUREMENT_DAILY_STATS=DailyStats
MEASUREMENT_SLEEP_SUMMARY=SleepSummary
MEASUREMENT_ACTIVITY_SESSION=ActivitySession
MEASUREMENT_ACTIVITY_LAP=ActivityLap
MEASUREMENT_VO2_MAX=VO2_Max
MEASUREMENT_RACE_PREDICTIONS=RacePredictions
MEASUREMENT_BODY_COMPOSITION=BodyComposition

# Intraday measurements (for live "today" data in stress/body battery tool)
# MEASUREMENT_STRESS_INTRADAY=StressIntraday
# MEASUREMENT_BODY_BATTERY_INTRADAY=BodyBatteryIntraday
# FIELD_STRESS_LEVEL=stressLevel
# FIELD_BODY_BATTERY_LEVEL=BodyBatteryLevel

# Training Status & Readiness (garmin-grafana v0.4.0+)
# Override only if your garmin-grafana schema uses different measurement/field names.
# MEASUREMENT_TRAINING_STATUS=TrainingStatus
# MEASUREMENT_TRAINING_READINESS=TrainingReadiness
# FIELD_TRAINING_STATUS_CODE=trainingStatus
# FIELD_TRAINING_STATUS_LABEL=trainingStatusFeedbackPhrase
# FIELD_ACUTE_LOAD=dailyTrainingLoadAcute
# FIELD_CHRONIC_LOAD=dailyTrainingLoadChronic
# FIELD_LOAD_BALANCE_RATIO=dailyAcuteChronicWorkloadRatio
# FIELD_ACWR_PERCENT=acwrPercent
# FIELD_FITNESS_TREND=fitnessTrend
# FIELD_READINESS_SCORE=trainingReadinessScore
# FIELD_READINESS_LABEL=trainingReadinessDescription

# Sleep physiology (SleepIntraday measurement — overnight epoch data)
# MEASUREMENT_SLEEP_INTRADAY=SleepIntraday
# FIELD_SLEEP_HR=heartRate
# FIELD_SLEEP_HRV=hrvData
# FIELD_SLEEP_RESPIRATION=respirationValue
# FIELD_SLEEP_SPO2=spo2Reading
# FIELD_SLEEP_STRESS=stressValue
# FIELD_SLEEP_BODY_BATTERY=bodyBattery
# FIELD_SLEEP_RESTLESS=sleepRestlessValue

# Activity load (fields in ActivitySummary)
# FIELD_TRAINING_LOAD=activityTrainingLoad
# FIELD_AEROBIC_TE=aerobicTrainingEffect
# FIELD_ANAEROBIC_TE=anaerobicTrainingEffect

# Daily energy balance (fields in DailyStats)
# FIELD_SEDENTARY_SECONDS=sedentarySeconds
# FIELD_ACTIVE_SECONDS=activeSeconds
# FIELD_HIGHLY_ACTIVE_SECONDS=highlyActiveSeconds
# FIELD_SLEEPING_SECONDS=sleepingSeconds
# FIELD_BMR_KCAL=bmrKilocalories
# FIELD_BB_DURING_SLEEP=bodyBatteryDuringSleep
# FIELD_ACTIVITY_STRESS_DUR=activityStressDuration
# FIELD_ACTIVITY_STRESS_PCT=activityStressPercentage

# Fitness age (FitnessAge measurement)
# MEASUREMENT_FITNESS_AGE=FitnessAge
# FIELD_FITNESS_AGE=fitnessAge
# FIELD_CHRONOLOGICAL_AGE=chronologicalAge
# FIELD_ACHIEVABLE_FITNESS_AGE=achievableFitnessAge

# Field names within measurements — override if your schema uses different names
FIELD_RESTING_HR=restingHeartRate
FIELD_HRV=hrvValue
FIELD_VO2_MAX_RUNNING=VO2_max_value
FIELD_VO2_MAX_CYCLING=VO2_max_value_cycling
FIELD_RACE_5K=time5K
FIELD_RACE_10K=time10K
FIELD_RACE_HALF=timeHalfMarathon
FIELD_RACE_MARATHON=timeMarathon
FIELD_WEIGHT=weight
FIELD_HR_ZONE_1=hrTimeInZone_1
FIELD_HR_ZONE_2=hrTimeInZone_2
FIELD_HR_ZONE_3=hrTimeInZone_3
FIELD_HR_ZONE_4=hrTimeInZone_4
FIELD_HR_ZONE_5=hrTimeInZone_5

# MCP / HTTP server
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Timezone for daily-aggregate queries (DailyStats, SleepSummary, etc.).
# Must be an IANA timezone identifier (e.g. Europe/Athens, America/New_York).
# Set this to match the USER_TIMEZONE value in your garmin-grafana .env file.
# Default "UTC" preserves existing behaviour — only change if you are in a
# non-UTC timezone and see daily metrics shifted by one day.
# QUERY_TIMEZONE=Europe/Athens

# Comma-separated allowed Host header values for DNS-rebinding protection.
# Each entry is matched as an exact string or a "hostname:*" port wildcard.
# Leave empty (default) to disable protection — required when accessing the
# server by a hostname other than localhost (e.g. pi5.pi-home, 192.168.1.x).
# Example: ALLOWED_HOSTS=pi5.pi-home:*,192.168.1.100:*,localhost:*
ALLOWED_HOSTS=
